# Database Configuration
POSTGRES_PASSWORD=StrongPassword123!

# Redis Configuration
REDIS_PASSWORD=RedisPassword123!

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_secure

# Config Server Git Configuration
CONFIG_GIT_URI=https://github.com/PrinceKumarMaurya591/hospitalmanagementcomplete
CONFIG_GIT_USERNAME=PrinceKumarMaurya591
CONFIG_GIT_PASSWORD='${GIT_PASSWORD}'
# Service Ports
CONFIG_SERVER_PORT=8888
EUREKA_SERVER_PORT=8761
API_GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
PATIENT_SERVICE_PORT=8082
DOCTOR_SERVICE_PORT=8083
APPOINTMENT_SERVICE_PORT=8084
BILLING_SERVICE_PORT=8085

# Database URLs
PATIENT_DB_URL=jdbc:postgresql://patient-db:5432/patient_db
APPOINTMENT_DB_URL=jdbc:postgresql://appointment-db:5432/appointment_db
DOCTOR_DB_URL=jdbc:postgresql://doctor-db:5432/doctor_db
BILLING_DB_URL=jdbc:postgresql://billing-db:5432/billing_db
USER_DB_URL=jdbc:postgresql://user-db:5432/user_db

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=hospital-group

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Eureka Configuration
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://service-registry:8761/eureka

# Spring Profiles
SPRING_PROFILES_ACTIVE=docker

# Application Names
SPRING_APPLICATION_NAME=config-server
USER_SERVICE_NAME=user-service
PATIENT_SERVICE_NAME=patient-service
DOCTOR_SERVICE_NAME=doctor-service
APPOINTMENT_SERVICE_NAME=appointment-service
BILLING_SERVICE_NAME=billing-service
API_GATEWAY_NAME=api-gateway

# Database Connection Pool
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=5
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000
SPRING_DATASOURCE_HIKARI_IDLE_TIMEOUT=600000
SPRING_DATASOURCE_HIKARI_MAX_LIFETIME=1800000

# JPA Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

# Logging Configuration
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_HOSPITAL=DEBUG
LOGGING_PATTERN_CONSOLE=%d{yyyy-MM-dd HH:mm:ss} - %msg%n

# Security Configuration
SECURITY_JWT_TOKEN_VALIDITY=86400000
SECURITY_JWT_TOKEN_REFRESH_VALIDITY=604800000

# Rate Limiting
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL_RATE=10
RATE_LIMIT_REFILL_DURATION=1

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
CORS_ALLOWED_METHODs=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# Actuator Configuration
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true

# Server Configuration
SERVER_COMPRESSION_ENABLED=true
SERVER_COMPRESSION_MIME_TYPES=text/html,text/xml,text/plain,text/css,text/javascript,application/javascript,application/json
SERVER_COMPRESSION_MIN_RESPONSE_SIZE=2048